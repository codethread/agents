{
	"name": "@codethread/agents",
	"version": "0.1.0",
	"description": "codethread's Pi extensions, agents, prompts, and themes",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi-prompt",
		"pi-theme",
		"pi-agent"
	],
	"files": [
		"pi-extensions"
	],
	"scripts": {
		"format": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"check": "npm run lint && npm run typecheck && npm run test && npm run format"
	},
	"pi": {
		"extensions": [
			"./pi-extensions/extensions"
		],
		"prompts": [
			"./pi-extensions/prompts"
		],
		"themes": [
			"./pi-extensions/themes"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-agent-core": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@eslint/js": "^9.25.1",
		"@types/node": "^24.0.0",
		"@types/nunjucks": "^3.2.6",
		"eslint": "^9.25.1",
		"eslint-config-prettier": "^10.1.2",
		"globals": "^16.0.0",
		"prettier": "^3.5.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.30.1",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"nunjucks": "^3.2.4",
		"zod": "^4.3.6"
	}
}
