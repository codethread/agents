{
	"name": "@codethread/agents",
	"version": "0.1.0",
	"description": "codethread's Pi extensions, agents, prompts, and themes",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi-prompt",
		"pi-theme",
		"pi-agent"
	],
	"files": [
		"pi-extensions",
		"prompts",
		"pi-themes",
		"pi-agents",
		"skills"
	],
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"format": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"check": "pnpm lint && pnpm typecheck && pnpm test && pnpm format",
		"verify": "pnpm check"
	},
	"pi": {
		"extensions": [
			"./pi-extensions/system-prompt/index.ts",
			"./pi-extensions/tools",
			"./pi-extensions/ui",
			"./pi-extensions/messaging",
			"./pi-extensions/cli"
		],
		"prompts": [
			"./prompts"
		],
		"themes": [
			"./pi-themes"
		],
		"skills": [
			"./skills"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-agent-core": "*",
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@eslint/js": "^9.25.1",
		"@gaodes/pi-test-harness": "^1.0.2",
		"@types/node": "^24.0.0",
		"@types/nunjucks": "^3.2.6",
		"eslint": "^9.25.1",
		"eslint-config-prettier": "^10.1.2",
		"globals": "^16.0.0",
		"prettier": "^3.5.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.30.1",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"@types/turndown": "^5.0.6",
		"linkedom": "^0.18.12",
		"nunjucks": "^3.2.4",
		"turndown": "^7.2.4",
		"zod": "^4.3.6"
	},
	"volta": {
		"node": "24.15.0"
	}
}
